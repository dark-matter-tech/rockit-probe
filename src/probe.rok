            if (stringLength(message) > 0) {
                __probeResults = __probeResults + "F:" + msg + " — " + message + "\n"
            } else {
                __probeResults = __probeResults + "F:" + msg + "\n"
            }
        }
        return
    }
    if (endsWith(s, suffix)) { return }
    val msg = "ASSERTION FAILED: \"" + s + "\" does not end with \"" + suffix + "\""
    if (stringLength(message) > 0) {
        panic(msg + " — " + message)
    }
    panic(msg)
}

// ── Bool equality ───────────────────────────────────────────────────────

fun assertEqualsBool(expected: Bool, actual: Bool, message: String = ""): Unit {
    if (__probeRecording == 1) {
        if (expected == actual) {
            __probeResults = __probeResults + "P\n"
        } else {
            __probeFailed = __probeFailed + 1
            val exp = if (expected) { "true" } else { "false" }
            val act = if (actual) { "true" } else { "false" }
            val msg = "expected " + exp + " but got " + act
            if (stringLength(message) > 0) {
                __probeResults = __probeResults + "F:" + msg + " — " + message + "\n"
            } else {
                __probeResults = __probeResults + "F:" + msg + "\n"
            }
        }
        return
    }
    if (expected == actual) { return }
    val exp = if (expected) { "true" } else { "false" }
    val act = if (actual) { "true" } else { "false" }
    val msg = "ASSERTION FAILED: expected " + exp + " but got " + act
    if (stringLength(message) > 0) {
        panic(msg + " — " + message)
    }
    panic(msg)
}

