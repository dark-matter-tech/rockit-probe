// rockit.test.probe — Probe Test Framework
// Assertion library for Rockit test files.
// Use with @Test annotation and `rockit test` command.

// ── Recording mode (used by --detailed flag) ──────────────────────────
// When __probeRecording == 1, assertions record P/F instead of panicking.

var __probeRecording: Int = 0
var __probeResults: String = ""
var __probeFailed: Int = 0

// ── Core assertions ─────────────────────────────────────────────────────

fun assert(condition: Bool, message: String = ""): Unit {
    if (__probeRecording == 1) {
        if (condition) {
            __probeResults = __probeResults + "P\n"
        } else {
            __probeFailed = __probeFailed + 1
            if (stringLength(message) > 0) {
                __probeResults = __probeResults + "F:" + message + "\n"
            } else {
                __probeResults = __probeResults + "F:assertion failed\n"
            }
        }
        return
    }
    if (condition) { return }
    if (stringLength(message) > 0) {
        panic("ASSERTION FAILED: " + message)
    }
    panic("ASSERTION FAILED")
}

fun assertTrue(condition: Bool, message: String = ""): Unit {
    if (__probeRecording == 1) {
        if (condition) {
            __probeResults = __probeResults + "P\n"
        } else {
            __probeFailed = __probeFailed + 1
            if (stringLength(message) > 0) {
                __probeResults = __probeResults + "F:expected true — " + message + "\n"
            } else {
                __probeResults = __probeResults + "F:expected true\n"
            }
        }
        return
    }
    if (condition) { return }
    if (stringLength(message) > 0) {
        panic("ASSERTION FAILED: expected true — " + message)
    }
    panic("ASSERTION FAILED: expected true")
}

fun assertFalse(condition: Bool, message: String = ""): Unit {
    if (__probeRecording == 1) {
        if (!condition) {
            __probeResults = __probeResults + "P\n"
        } else {
            __probeFailed = __probeFailed + 1
            if (stringLength(message) > 0) {
                __probeResults = __probeResults + "F:expected false — " + message + "\n"
            } else {
                __probeResults = __probeResults + "F:expected false\n"
            }
        }
        return
    }
    if (!condition) { return }
    if (stringLength(message) > 0) {
        panic("ASSERTION FAILED: expected false — " + message)
    }
    panic("ASSERTION FAILED: expected false")
}

// ── Equality assertions ─────────────────────────────────────────────────

fun assertEquals(expected: Int, actual: Int, message: String = ""): Unit {
    if (__probeRecording == 1) {
        if (expected == actual) {
            __probeResults = __probeResults + "P\n"
        } else {
            __probeFailed = __probeFailed + 1
            val msg = "expected " + toString(expected) + " but got " + toString(actual)
            if (stringLength(message) > 0) {
                __probeResults = __probeResults + "F:" + msg + " — " + message + "\n"
            } else {
                __probeResults = __probeResults + "F:" + msg + "\n"
            }
        }
        return
    }
    if (expected == actual) { return }
    val msg = "ASSERTION FAILED: expected " + toString(expected) + " but got " + toString(actual)
    if (stringLength(message) > 0) {
        panic(msg + " — " + message)
    }
    panic(msg)
}

fun assertEqualsStr(expected: String, actual: String, message: String = ""): Unit {
    if (__probeRecording == 1) {
        if (expected == actual) {
            __probeResults = __probeResults + "P\n"
        } else {
            __probeFailed = __probeFailed + 1
            val msg = "expected \"" + expected + "\" but got \"" + actual + "\""
            if (stringLength(message) > 0) {
                __probeResults = __probeResults + "F:" + msg + " — " + message + "\n"
            } else {
                __probeResults = __probeResults + "F:" + msg + "\n"
            }
        }
        return
    }
    if (expected == actual) { return }
    val msg = "ASSERTION FAILED: expected \"" + expected + "\" but got \"" + actual + "\""
    if (stringLength(message) > 0) {
        panic(msg + " — " + message)
    }
    panic(msg)
}

fun assertNotEquals(a: Int, b: Int, message: String = ""): Unit {
    if (__probeRecording == 1) {
        if (a != b) {
            __probeResults = __probeResults + "P\n"
        } else {
            __probeFailed = __probeFailed + 1
            val msg = "expected values to differ, both are " + toString(a)
            if (stringLength(message) > 0) {
                __probeResults = __probeResults + "F:" + msg + " — " + message + "\n"
            } else {
                __probeResults = __probeResults + "F:" + msg + "\n"
            }
        }
        return
    }
    if (a != b) { return }
    val msg = "ASSERTION FAILED: expected values to differ, both are " + toString(a)
    if (stringLength(message) > 0) {
        panic(msg + " — " + message)
    }
    panic(msg)
}

